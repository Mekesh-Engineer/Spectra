{
  "name": "spectra",
  "private": true,
  "version": "1.0.0",
  "description": "Spectra - Full Stack Application with AI-powered measurement engine",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "server": "tsx server/server.ts",
    "dev:server": "tsx watch server/server.ts",
    "dev:all": "concurrently -n AI,API,WEB -c blue,green,cyan \"npm run ai:server\" \"npm run dev:server\" \"npm run dev\"",
    "ai:server": ".venv\\Scripts\\python.exe ai-engine/detect_service.py",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^5.0.0",
    "express-rate-limit": "^8.3.1",
    "firebase": "^12.11.0",
    "firebase-admin": "^13.7.0",
    "framer-motion": "^11.0.0",
    "helmet": "^8.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.0.0",
    "recharts": "^2.0.0",
    "ws": "^8.19.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.2.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/express-rate-limit": "^5.1.3",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.0.0",
    "eslint": "^9.0.0",
    "pg": "^8.20.0",
    "tailwindcss": "4.2.1",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0"
  }
}
